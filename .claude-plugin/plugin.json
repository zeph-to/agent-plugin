{
  "name": "zeph",
  "version": "0.2.0",
  "description": "AI agent notifications via Zeph — notify, prompt, input across devices",
  "author": {
    "name": "zeph-to",
    "url": "https://github.com/zeph-to"
  },
  "repository": "https://github.com/zeph-to/plugin",
  "license": "MIT",
  "keywords": ["zeph", "notification", "push", "mcp", "prompt"],
  "mcpServers": "./.mcp.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/zeph-setup.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/zeph-stop.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/zeph-ask.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
